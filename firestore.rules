rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isAdmin() {
      return isAuth() && 
             request.auth.token.email == 'armandoaventurasve@gmail.com' && 
             request.auth.token.email_verified == true;
    }
    function canUpdateReserva() {
      return isAuth() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        resource.data.instructorId == request.auth.uid
      );
    }

    // ──────────────────────────────────────────
    // COLECCIÓN: LOCKS (Privada)
    // ──────────────────────────────────────────
    match /locks/{lockId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.expiresAt is timestamp &&
                      request.resource.data.expiresAt <= request.time + duration.value(900, 's') &&
                      (
                        !exists(/databases/$(database)/documents/locks/$(lockId)) ||
                        get(/databases/$(database)/documents/locks/$(lockId)).data.expiresAt < request.time
                      ); 
      allow update: if isAuth() &&
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['expiresAt']);
      allow delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ──────────────────────────────────────────
    // COLECCIÓN: OCUPACIÓN TEMPORAL (Pública, Anonimizada)
    // ──────────────────────────────────────────
    match /ocupacionTemporal/{lockId} {
      allow read: if isAuth();
      allow create: if isAuth() && 
                      request.resource.data.expiresAt is timestamp &&
                      request.resource.data.expiresAt <= request.time + duration.value(900, 's') &&
                      getAfter(/databases/$(database)/documents/locks/$(lockId)).data.userId == request.auth.uid;
      allow update: if isAuth() &&
                      exists(/databases/$(database)/documents/locks/$(lockId)) &&
                      get(/databases/$(database)/documents/locks/$(lockId)).data.userId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['expiresAt']);
      allow delete: if isAuth() && 
                      (
                        (exists(/databases/$(database)/documents/locks/$(lockId)) &&
                         get(/databases/$(database)/documents/locks/$(lockId)).data.userId == request.auth.uid) ||
                        !exists(/databases/$(database)/documents/locks/$(lockId)) ||
                        get(/databases/$(database)/documents/locks/$(lockId)).data.expiresAt < request.time ||
                        isAdmin()
                      );
    }

    // ──────────────────────────────────────────
    // COLECCIÓN: OCUPACIÓN CONFIRMADA (Pública, Anonimizada, Espejo de Reservas)
    // ──────────────────────────────────────────
    match /ocupacionConfirmada/{docId} {
      allow read: if isAuth();
      allow create: if isAdmin() || (
        isAuth() && 
        request.resource.data.userId == request.auth.uid &&
        getAfter(/databases/$(database)/documents/artifacts/motoescuela-pro-v1/public/data/reservas/$(docId)).data.userId == request.auth.uid
      );
      allow update, delete: if isAdmin();
    }

    match /artifacts/{appId}/public/data {

      match /configuraciones/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
      match /sedes/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
      match /horarios/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
      match /cursos/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
      match /instructores/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
      match /proveedores/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
      match /motos/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }
      match /admins/{docId} { allow read: if isAuth(); allow write: if isAdmin(); }

      match /reservas/{docId} {
        allow read: if isAuth() && (
          isAdmin() || 
          resource.data.userId == request.auth.uid || 
          resource.data.instructorId == request.auth.uid
        );

        allow create: if isAuth() && 
                        request.resource.data.userId == request.auth.uid &&
                        request.resource.data.estadoPago == 'Pendiente' &&
                        request.resource.data.precio > 0 &&
                        !('sesionTotalInicio' in request.resource.data) &&
                        !('pausaTotalAcumulada' in request.resource.data);

        allow update: if canUpdateReserva() && (
          isAdmin() || 
          (
            request.resource.data.precio == resource.data.precio &&
            (
              request.resource.data.estadoPago == resource.data.estadoPago ||
              (resource.data.estadoPago == 'Rechazado' && request.resource.data.estadoPago == 'Pendiente')
            ) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'pagoRef', 
              'pagoBanco', 
              'pagoTelefono', 
              'pagoCedula', 
              'estadoPago'
            ])
          )
        );

        allow delete: if false;
      }

      match /movimientos/{docId} {
        allow read: if isAuth() && (isAdmin() || resource.data.userId == request.auth.uid);
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }

      match /notificaciones/{docId} {
        allow read: if isAuth() && (isAdmin() || resource.data.userId == request.auth.uid);
        allow create: if isAuth() && (isAdmin() || request.auth.uid == request.resource.data.userId);
        allow update: if isAuth() && (isAdmin() || resource.data.userId == request.auth.uid);
        allow delete: if isAdmin();
      }

      match /progresoInscripcion/{docId} {
        allow get: if true;
        allow list: if false;
        allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
      }
    }
  }
}
